cxx := env("CXX", "g++")
cxxflags := "-std=c++20 -O3 -march=native -mtune=native -flto -funroll-loops -fomit-frame-pointer -fno-exceptions -fno-rtti -DNDEBUG -pthread -Wall -Wextra -Wpedantic"
ldflags := "-flto -pthread"

# Build Sharvil's reference implementation
build:
    {{cxx}} {{cxxflags}} -o erdos396_ref erdos_problem_396.cpp {{ldflags}}

# Remove build artifacts
clean:
    rm -f erdos396_ref
