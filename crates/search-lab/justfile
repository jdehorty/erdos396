# search-lab — build and benchmark recipes for Rust and C++ implementations

# Override with: just threads=8 bench
threads := `python3 -c "import os; print(os.cpu_count() or 4)"`

# ─── Build ────────────────────────────────────────────────────────────

# Build the Rust binary in release mode
build-rust:
    cargo build -p erdos396-search-lab --release

# Build the C++ reference binary
build-cpp:
    cd cpp-reference && just build

# Build everything
build: build-rust build-cpp

# ─── Benchmark ────────────────────────────────────────────────────────
#
# All benchmarks run k=8, k=9, k=10 over the known witness ranges:
#   k=8:  [1, 339_949_253)                witness at 339_949_252
#   k=9:  [339_949_252, 1_019_547_845)    witness at 1_019_547_844
#   k=10: [1_019_547_844, 17_609_764_995) witness at 17_609_764_994

# Benchmark Rust implementation
bench-rust: build-rust
    #!/usr/bin/env bash
    set -euo pipefail
    BIN="../../target/release/erdos396-search-lab"
    THREADS="{{threads}}"
    OUT="bench-rust.md"

    if [[ "$(uname)" == "Darwin" ]]; then
        cpu=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")
        mem_bytes=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
        mem="$(( mem_bytes / 1073741824 )) GB"
        os_info="$(sw_vers -productName 2>/dev/null || echo macOS) $(sw_vers -productVersion 2>/dev/null || echo "")"
    else
        cpu=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "unknown")
        mem_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}' || echo 0)
        mem="$(( mem_kb / 1048576 )) GB"
        os_info=$(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d= -f2 | tr -d '"' || echo "Linux")
    fi
    rustc_ver=$(rustc --version 2>/dev/null || echo "unknown")
    git_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    timestamp=$(date -u '+%Y-%m-%d %H:%M:%S UTC')

    {
        echo "# search-lab Benchmark (Rust)"
        echo ""
        echo "Measures wall-clock throughput of the witness search over the known"
        echo "witness ranges for k=8, k=9, and k=10. These ranges reproduce the"
        echo "same search space traversed by the C++ reference implementation,"
        echo "providing a standardized baseline for comparing optimizations."
        echo ""
        echo "## Environment"
        echo ""
        echo "| | |"
        echo "|---|---|"
        echo "| **CPU** | $cpu |"
        echo "| **Memory** | $mem |"
        echo "| **OS** | $os_info |"
        echo "| **Threads** | $THREADS |"
        echo "| **rustc** | \`$rustc_ver\` |"
        echo "| **Commit** | \`$git_hash\` |"
        echo "| **Date** | $timestamp |"
        echo ""
        echo "## Results"
        echo ""
        echo "| k | Range | Candidates | Time (s) | Throughput (M/s) |"
        echo "|--:|:------|-----------:|---------:|-----------------:|"
    } | tee "$OUT"

    bench() {
        local k=$1 start=$2 end=$3
        local range=$(( end - start ))
        printf "  k=%-4s  %-36s" "$k" "[$start, $end)" >&2
        local t0
        t0=$(python3 -c 'import time; print(time.time())')
        "$BIN" -k "$k" --kmax "$k" --start "$start" --end "$end" \
            --threads "$THREADS" --run-log 100 > /dev/null 2>&1 || true
        local t1
        t1=$(python3 -c 'import time; print(time.time())')
        local elapsed speed range_fmt
        elapsed=$(python3 -c "print(f'{$t1 - $t0:.3f}')")
        speed=$(python3 -c "print(f'{$range / ($t1 - $t0) / 1e6:.1f}')")
        range_fmt=$(python3 -c "print(f'{$range:,}')")
        echo "  ${elapsed}s  ${speed} M/s" >&2
        echo "| $k | \`[$start, $end)\` | $range_fmt | $elapsed | $speed |" | tee -a "$OUT"
    }

    bench 8  1          339949253
    bench 9  339949252  1019547845
    bench 10 1019547844 17609764995

    echo "" | tee -a "$OUT"
    echo "Results written to: $OUT" >&2
    rm -f results.txt checkpoint.txt checkpoint.tmp 2>/dev/null || true

# Benchmark C++ reference implementation (Sharvil Kesarwani)
bench-cpp: build-cpp
    #!/usr/bin/env bash
    set -euo pipefail
    BIN="cpp-reference/erdos396_ref"
    OUT="bench-cpp.md"

    if [[ "$(uname)" == "Darwin" ]]; then
        cpu=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")
        mem_bytes=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
        mem="$(( mem_bytes / 1073741824 )) GB"
        os_info="$(sw_vers -productName 2>/dev/null || echo macOS) $(sw_vers -productVersion 2>/dev/null || echo "")"
    else
        cpu=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "unknown")
        mem_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}' || echo 0)
        mem="$(( mem_kb / 1048576 )) GB"
        os_info=$(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d= -f2 | tr -d '"' || echo "Linux")
    fi
    cxx_ver=$(${CXX:-g++} --version 2>/dev/null | head -1 || echo "unknown")
    git_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    timestamp=$(date -u '+%Y-%m-%d %H:%M:%S UTC')

    # Sharvil's binary has no CLI flags. It reads checkpoint-396.txt to
    # determine where to resume. We seed it at k=8, start=1 so it naturally
    # traverses the same ranges: k=8 [1..], k=9 [339M..], k=10 [1019M..].
    # The binary reports its own per-k timing, which we parse.
    # Thread count is hardcoded to hardware_concurrency() in the binary.
    hw_threads=$(python3 -c "import os; print(os.cpu_count() or '?')")

    {
        echo "# search-lab Benchmark (C++ reference, Sharvil Kesarwani)"
        echo ""
        echo "Measures wall-clock throughput of the witness search over the known"
        echo "witness ranges for k=8, k=9, and k=10. These ranges reproduce the"
        echo "same search space traversed by the C++ reference implementation,"
        echo "providing a standardized baseline for comparing optimizations."
        echo ""
        echo "## Environment"
        echo ""
        echo "| | |"
        echo "|---|---|"
        echo "| **CPU** | $cpu |"
        echo "| **Memory** | $mem |"
        echo "| **OS** | $os_info |"
        echo "| **Threads** | $hw_threads (hardcoded to hardware_concurrency) |"
        echo "| **C++** | \`$cxx_ver\` |"
        echo "| **Commit** | \`$git_hash\` |"
        echo "| **Date** | $timestamp |"
        echo ""
        echo "## Results"
        echo ""
        echo "| k | Range | Candidates | Time (s) | Throughput (M/s) |"
        echo "|--:|:------|-----------:|---------:|-----------------:|"
    } | tee "$OUT"

    # Known ranges for table formatting
    declare -A STARTS=([8]=1 [9]=339949252 [10]=1019547844)
    declare -A ENDS=([8]=339949253 [9]=1019547845 [10]=17609764995)

    # Seed checkpoint so it starts at k=8 from position 1.
    # The binary writes per-k results to results-396.txt as it goes.
    # We poll that file and kill the process once k=10 completes.
    rm -f cpp-reference/results-396.txt
    echo "8 1" > cpp-reference/checkpoint-396.txt

    echo "  Running k=8,9,10 (seeded via checkpoint)..." >&2

    cd cpp-reference
    ./erdos396_ref > /dev/null 2>&1 &
    PID=$!

    # Poll results file for k=10 completion, then stop
    while ! grep -q "^k = 10" results-396.txt 2>/dev/null; do
        sleep 0.2
    done
    kill $PID 2>/dev/null || true
    wait $PID 2>/dev/null || true

    cd ..

    # Parse the first 3 result lines from the file (k=8, k=9, k=10)
    head -3 cpp-reference/results-396.txt | while IFS='|' read -r k_field n_field time_field speed_field; do
        k=$(echo "$k_field" | tr -dc '0-9')
        elapsed=$(echo "$time_field" | grep -oE '[0-9]+\.[0-9]+')
        speed=$(echo "$speed_field" | grep -oE '[0-9]+\.[0-9]+')

        start=${STARTS[$k]:-"?"}
        end=${ENDS[$k]:-"?"}
        range=$(( end - start ))
        range_fmt=$(python3 -c "print(f'{$range:,}')")

        printf "  k=%-4s  %-36s  %ss  %s M/s\n" "$k" "[$start, $end)" "$elapsed" "$speed" >&2
        echo "| $k | \`[$start, $end)\` | $range_fmt | $elapsed | $speed |"
    done >> "$OUT"

    echo "" | tee -a "$OUT"
    echo "Results written to: $OUT" >&2

    # Clean up
    rm -f cpp-reference/checkpoint-396.txt cpp-reference/checkpoint-396.tmp \
          cpp-reference/results-396.txt 2>/dev/null || true

# Benchmark both implementations
bench: bench-rust bench-cpp

# ─── Clean ────────────────────────────────────────────────────────────

# Remove build artifacts
clean:
    cargo clean -p erdos396-search-lab
    cd cpp-reference && just clean
