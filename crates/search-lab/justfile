# search-lab — build and benchmark recipes for Rust and C++ implementations

# Override with: just threads=8 bench
threads := `python3 -c "import os; print(os.cpu_count() or 4)"`

# ─── Build ────────────────────────────────────────────────────────────

# Build the Rust binary in release mode
build-rust:
    cargo build -p erdos396-search-lab --release

# Build the C++ reference binary
build-cpp:
    cd cpp-reference && just build

# Build everything
build: build-rust build-cpp

# ─── Benchmark ────────────────────────────────────────────────────────
#
# Benchmarks run k=8, k=9, k=10 over full witness ranges, plus k=13
# over a representative 10B-candidate slice at production scale.
#
# Known witnesses:
#   k=8:  339_949_252
#   k=9:  1_019_547_844
#   k=10: 17_609_764_994
#   k=13: 18_253_129_921_842
#
# NOTE: Run bench-rust and bench-cpp separately (not via `just bench`)
# to avoid thermal throttling from back-to-back CPU saturation.

# Benchmark Rust implementation
bench-rust: build-rust
    #!/usr/bin/env bash
    set -euo pipefail
    BIN="../../target/release/erdos396-search-lab"
    THREADS="{{threads}}"
    OUT="bench-rust.md"

    if [[ "$(uname)" == "Darwin" ]]; then
        cpu=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")
        mem_bytes=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
        mem="$(( mem_bytes / 1073741824 )) GB"
        os_info="$(sw_vers -productName 2>/dev/null || echo macOS) $(sw_vers -productVersion 2>/dev/null || echo "")"
    else
        cpu=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "unknown")
        mem_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}' || echo 0)
        mem="$(( mem_kb / 1048576 )) GB"
        os_info=$(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d= -f2 | tr -d '"' || echo "Linux")
    fi
    rustc_ver=$(rustc --version 2>/dev/null || echo "unknown")
    git_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    timestamp=$(date -u '+%Y-%m-%d %H:%M:%S UTC')

    {
        echo "# search-lab Benchmark (Rust)"
        echo ""
        echo "Measures per-k throughput of the witness search (sieve time excluded)."
        echo "k=8, k=9, k=10 run over full witness ranges. k=13 runs a 10B-candidate"
        echo "slice at production scale (sieve_limit ~ 6M primes)."
        echo ""
        echo "## Environment"
        echo ""
        echo "| | |"
        echo "|---|---|"
        echo "| **CPU** | $cpu |"
        echo "| **Memory** | $mem |"
        echo "| **OS** | $os_info |"
        echo "| **Threads** | $THREADS |"
        echo "| **rustc** | \`$rustc_ver\` |"
        echo "| **Commit** | \`$git_hash\` |"
        echo "| **Date** | $timestamp |"
        echo ""
        echo "## Results"
        echo ""
        echo "| k | Range | Candidates | Time (s) | Throughput (M/s) |"
        echo "|--:|:------|-----------:|---------:|-----------------:|"
    } | tee "$OUT"

    # --- Phase 1: k=8,9,10 in a single invocation (sieve amortized) ---
    echo "  Running k=8,9,10 in single process (sieve shared)..." >&2
    TMPOUT=$(mktemp)
    "$BIN" -k 8 --kmax 10 --start 1 \
        --threads "$THREADS" --run-log 100 > "$TMPOUT" 2>/dev/null || true

    # --- Phase 2: k=13 separate (different start range) ---
    echo "  Running k=13 [18.243T, 18.253T)..." >&2
    "$BIN" -k 13 --kmax 13 --start 18243129921842 --end 18253129921843 \
        --threads "$THREADS" --run-log 100 >> "$TMPOUT" 2>/dev/null || true

    # Parse all k= lines with Python (avoids bash associative array issues)
    python3 parse_bench.py "$TMPOUT" >> "$OUT" 2>&2

    rm -f "$TMPOUT"

    echo "" | tee -a "$OUT"
    echo "Results written to: $OUT" >&2
    rm -f results.txt checkpoint.txt checkpoint.tmp 2>/dev/null || true

# Benchmark C++ reference implementation (Sharvil Kesarwani)
bench-cpp: build-cpp
    #!/usr/bin/env bash
    set -euo pipefail
    BIN="cpp-reference/erdos396_ref"
    OUT="bench-cpp.md"

    if [[ "$(uname)" == "Darwin" ]]; then
        cpu=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "unknown")
        mem_bytes=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
        mem="$(( mem_bytes / 1073741824 )) GB"
        os_info="$(sw_vers -productName 2>/dev/null || echo macOS) $(sw_vers -productVersion 2>/dev/null || echo "")"
    else
        cpu=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "unknown")
        mem_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}' || echo 0)
        mem="$(( mem_kb / 1048576 )) GB"
        os_info=$(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d= -f2 | tr -d '"' || echo "Linux")
    fi
    cxx_ver=$(${CXX:-g++} --version 2>/dev/null | head -1 || echo "unknown")
    git_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    timestamp=$(date -u '+%Y-%m-%d %H:%M:%S UTC')
    hw_threads=$(python3 -c "import os; print(os.cpu_count() or '?')")

    {
        echo "# search-lab Benchmark (C++ reference, Sharvil Kesarwani)"
        echo ""
        echo "Measures wall-clock throughput of the witness search. k=8, k=9, k=10"
        echo "run over the full known witness ranges. k=13 runs a 10B-candidate"
        echo "slice at production scale (sieve_limit ~ 6M primes)."
        echo ""
        echo "Note: thread count is hardcoded to hardware_concurrency() in the binary."
        echo ""
        echo "## Environment"
        echo ""
        echo "| | |"
        echo "|---|---|"
        echo "| **CPU** | $cpu |"
        echo "| **Memory** | $mem |"
        echo "| **OS** | $os_info |"
        echo "| **Threads** | $hw_threads |"
        echo "| **C++** | \`$cxx_ver\` |"
        echo "| **Commit** | \`$git_hash\` |"
        echo "| **Date** | $timestamp |"
        echo ""
        echo "## Results"
        echo ""
        echo "| k | Range | Candidates | Time (s) | Throughput (M/s) |"
        echo "|--:|:------|-----------:|---------:|-----------------:|"
    } | tee "$OUT"

    # Known ranges for table formatting
    declare -A STARTS=([8]=1 [9]=339949252 [10]=1019547844 [13]=18243129921842)
    declare -A ENDS=([8]=339949253 [9]=1019547845 [10]=17609764995 [13]=18253129921843)

    # --- Phase 1: k=8,9,10 via natural chaining ---
    rm -f cpp-reference/results-396.txt
    echo "8 1" > cpp-reference/checkpoint-396.txt

    echo "  Running k=8,9,10 (seeded via checkpoint)..." >&2

    cd cpp-reference
    ./erdos396_ref > /dev/null 2>&1 &
    PID=$!
    while ! grep -q "^k = 10" results-396.txt 2>/dev/null; do
        sleep 0.2
    done
    kill $PID 2>/dev/null || true
    wait $PID 2>/dev/null || true
    cd ..

    head -3 cpp-reference/results-396.txt | while IFS='|' read -r k_field n_field time_field speed_field; do
        k=$(echo "$k_field" | tr -dc '0-9')
        elapsed=$(echo "$time_field" | grep -oE '[0-9]+\.[0-9]+')
        speed=$(echo "$speed_field" | grep -oE '[0-9]+\.[0-9]+')

        start=${STARTS[$k]:-"?"}
        end=${ENDS[$k]:-"?"}
        range=$(( end - start ))
        range_fmt=$(python3 -c "print(f'{$range:,}')")

        printf "  k=%-4s  %-36s  %ss  %s M/s\n" "$k" "[$start, $end)" "$elapsed" "$speed" >&2
        echo "| $k | \`[$start, $end)\` | $range_fmt | $elapsed | $speed |"
    done >> "$OUT"

    # --- Phase 2: k=13 via checkpoint at 10B before witness ---
    rm -f cpp-reference/results-396.txt
    echo "13 18243129921842" > cpp-reference/checkpoint-396.txt

    echo "  Running k=13 [18.243T, 18.253T) (seeded via checkpoint)..." >&2

    cd cpp-reference
    ./erdos396_ref > /dev/null 2>&1 &
    PID=$!
    while ! grep -q "^k = 13" results-396.txt 2>/dev/null; do
        sleep 0.5
    done
    kill $PID 2>/dev/null || true
    wait $PID 2>/dev/null || true
    cd ..

    # Parse k=13 result
    grep "^k = 13" cpp-reference/results-396.txt | head -1 | while IFS='|' read -r k_field n_field time_field speed_field; do
        k=13
        elapsed=$(echo "$time_field" | grep -oE '[0-9]+\.[0-9]+')
        speed=$(echo "$speed_field" | grep -oE '[0-9]+\.[0-9]+')

        start=${STARTS[$k]}
        end=${ENDS[$k]}
        range=$(( end - start ))
        range_fmt=$(python3 -c "print(f'{$range:,}')")

        printf "  k=%-4s  %-36s  %ss  %s M/s\n" "$k" "[$start, $end)" "$elapsed" "$speed" >&2
        echo "| $k | \`[$start, $end)\` | $range_fmt | $elapsed | $speed |"
    done >> "$OUT"

    echo "" | tee -a "$OUT"
    echo "Results written to: $OUT" >&2

    # Clean up
    rm -f cpp-reference/checkpoint-396.txt cpp-reference/checkpoint-396.tmp \
          cpp-reference/results-396.txt 2>/dev/null || true

# Benchmark both implementations (NOTE: run separately for accurate thermal results)
bench: bench-rust bench-cpp

# ─── Clean ────────────────────────────────────────────────────────────

# Remove build artifacts
clean:
    cargo clean -p erdos396-search-lab
    cd cpp-reference && just clean
