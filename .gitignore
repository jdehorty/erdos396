# Rust build artifacts
/target/
**/*.rs.bk

# Cargo lock for library crates (keep for binaries — this is a binary crate)
# Cargo.lock is intentionally tracked

# Checkpoint and runtime output directories (generated at runtime)
checkpoints*/
checkpoint_*.json
validate_*/

# Runtime reports and run logs (generated by search/validate/audit binaries)
search_report_*.json
validate_report_*.json
audit_report_*.json
runs_*.jsonl

# Curated validation certificates are tracked (override the runtime ignores above)
!certificates/validate/validate_report_*.json

# Generated analysis artifacts not intended for the public repo
/artifacts/
/data/run_corpus/

# Python
__pycache__/
*.pyc
*.pyo

# OS metadata
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE / editor
.idea/
.vscode/
*.iml

# Claude Code / Codex tooling (not part of this project)
.claude/
.codex/

# Environment and secrets
.env
.env.*

# Logs
*.log

# Status reports (generated by /erdos-servers-update skill)
/reports/

# Performance journal (local benchmarking notes)
perf_journal.md

# Legacy local-only speed directories (superseded by crates/speed)
/speed/
/speed-rust/

# Third-party reference implementations (local only)
/third_party/

# Local benchmark scripts and output
/bench_rust.sh
/checkpoint.txt
/results.txt

# search-lab benchmark output (generated by `just bench`)
crates/search-lab/bench-*.md
crates/search-lab/results.txt
crates/search-lab/checkpoint.txt
